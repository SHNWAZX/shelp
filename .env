# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/senpaihelppbot

# Port for web server (Render uses PORT env var automatically)
PORT=3000

# Bot admin user ID (your Telegram user ID)
ADMIN_ID=your_telegram_user_id

# Uptime Robot ping URL (optional)
UPTIME_ROBOT_URL=https://your-render-app.onrender.com/ping
